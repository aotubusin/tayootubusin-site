<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or profile.name }} · Operations &amp; Transformation Leader</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/style.css">
</head>
<body>

<header>
  <div class="wrap nav">
    <a href="/" class="brand">
      {% if profile.logo %}<img src="{{ profile.logo }}" alt="{{ profile.name }}" style="height:30px;width:auto;">{% else %}<span class="dot"></span>{{ profile.name | upper }}{% endif %}
    </a>
    <nav class="links">
      <a href="/#about">About</a>
      <a href="/#impact">Profile</a>
      <a href="/#expertise">Expertise</a>
      <a href="/blog/">Writing</a>
      {% if profile.medium %}<a href="{{ profile.medium }}">Medium</a>{% endif %}
    </nav>
    <button class="nav-cta" onclick="location.href='/#contact'">Get in touch →</button>
    <button class="menu-toggle" id="menuBtn" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</header>

{{ content | safe }}

<footer>
  <div class="wrap">
    {% if profile.logo_dark %}<img src="{{ profile.logo_dark }}" alt="{{ profile.name }}" class="foot-logo" style="height:40px;margin-bottom:20px;">{% else %}<div class="foot-word">{{ profile.name | upper | replace("TAYO ", "") }}</div>{% endif %}
    <div class="foot-grid">
      <div class="foot-col"><h4>Explore</h4><a href="/#about">About</a><a href="/#impact">Profile</a><a href="/#expertise">Expertise</a><a href="/blog/">Writing</a><a href="/#beyond">Beyond work</a></div>
      <div class="foot-col"><h4>Connect</h4><a href="{{ profile.linkedin }}">LinkedIn</a><a href="https://www.researchgate.net/profile/Adetayo-Otubusin">Research profile</a>{% if profile.medium %}<a href="{{ profile.medium }}">Medium</a>{% endif %}<a href="mailto:{{ profile.email }}">Email</a><a href="https://tayorskifellowship.org">The Fellowship</a></div>
    </div>
    <div class="foot-bottom">
      <div>© 2026 {{ profile.name }} · MBA, MEng (Hons)</div>
      <div>Operations &amp; Transformation Leader · Derby, UK</div>
    </div>
  </div>
</footer>

</body>
</html>
