---
layout: base.njk
title: Writing
permalink: /blog/index.html
---

<section class="blog-list">
  <h1>Writing &amp; thinking</h1>

  <h2>From this site</h2>
  {% for post in collections.posts %}
    <article class="post-card">
      <p class="post-meta">{{ post.date | readableDate }}{% if post.data.category %} · {{ post.data.category }}{% endif %}</p>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <p>{{ post.data.excerpt }}</p>
      {% if post.data.tags %}
        <p class="tags">{% for t in post.data.tags %}<span>#{{ t }}</span> {% endfor %}</p>
      {% endif %}
    </article>
  {% else %}
    <p>No posts yet. Add your first one from the <a href="/admin/">content manager</a>.</p>
  {% endfor %}

  {% if medium and medium.length %}
    <h2>From Medium</h2>
    {% set mediumPosts = medium | limit(5) %}
    {% for m in mediumPosts %}
      <article class="post-card">
        <p class="post-meta">{{ m.date | readableDate }} · Medium</p>
        <h3><a href="{{ m.link }}">{{ m.title }}</a></h3>
        <p>{{ m.excerpt }}…</p>
      </article>
    {% endfor %}
  {% endif %}
</section>
