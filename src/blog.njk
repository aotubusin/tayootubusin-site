---
layout: base.njk
title: Writing
permalink: /blog/index.html
---

<section class="block">
  <div class="wrap">
    <div class="kicker">Writing &amp; thinking</div>
    <h2 class="big">Ideas worth <span class="serif">sharing.</span></h2>
    <p class="lead-p blog-intro">Occasional essays on transformation, leadership, engineering, and giving back.</p>

    <div class="blog-list">
      {% for post in collections.posts %}
      <a class="blog-item" href="{{ post.url }}">
        <div class="blog-meta">{{ post.date | readableDate }}{% if post.data.category %} · {{ post.data.category }}{% endif %}</div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.excerpt }}</p>
        {% if post.data.tags %}<div class="blog-tags">{% for t in post.data.tags %}<span>#{{ t }}</span>{% if not loop.last %} {% endif %}{% endfor %}</div>{% endif %}
      </a>
      {% else %}
      <p class="lead-p">No posts yet. Add your first from the content manager.</p>
      {% endfor %}

      {% if medium %}{% set mediumPosts = medium | limit(6) %}{% for m in mediumPosts %}
      <a class="blog-item" href="{{ m.link }}">
        <div class="blog-meta">{{ m.date | readableDate }} · Medium</div>
        <h3>{{ m.title }}</h3>
        <p>{{ m.excerpt }}…</p>
      </a>
      {% endfor %}{% endif %}
    </div>
  </div>
</section>
