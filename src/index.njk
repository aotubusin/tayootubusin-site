---
layout: base.njk
title: Tayo Otubusin
permalink: /index.html
---

<!-- HERO -->
<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-text">
      <div class="roles reveal">{{ profile.roles }}</div>
      <h1 class="reveal">{{ profile.name }}</h1>
      <p class="hero-tagline reveal">{{ profile.tagline }}</p>
      <p class="hero-lead reveal">{{ profile.lead }}</p>
      <div class="hero-actions reveal">
        <a href="#about" class="btn-solid">My story</a>
        <a href="#impact" class="btn-line">At a glance</a>
      </div>
    </div>
    <div class="hero-portrait reveal-r">
      {% if profile.portrait %}
        <img src="{{ profile.portrait }}" alt="{{ profile.name }}">
      {% else %}
        <div class="hp-ring"></div>
        <div class="hp-initials">TO</div>
        <div class="hp-note">Your professional portrait goes here</div>
      {% endif %}
    </div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee">
  <div class="marquee-track">
    <span>Turn strategy into action</span><span>Make change stick</span><span>Build for impact</span><span>Lift as you climb</span><span>Turn strategy into action</span><span>Make change stick</span><span>Build for impact</span><span>Lift as you climb</span>
  </div>
</div>

<!-- SIGNATURE FRAMEWORK -->
<section class="framework">
  <div class="wrap">
    <div class="fw-head reveal">
      <div class="fw-title">A method, <span class="serif">not a guess.</span></div>
      <p class="fw-sub">How I turn strategic intent into lasting change, in four repeatable steps.</p>
    </div>
    <div class="fw-flow">
      <div class="fw-step reveal">
        <div class="fw-node">01</div>
        <div class="fw-verb">Design</div>
        <div class="fw-phrase">the operating model around process, performance and capability.</div>
      </div>
      <div class="fw-step reveal">
        <div class="fw-node">02</div>
        <div class="fw-verb">Deliver</div>
        <div class="fw-phrase">the programme as complex, cross-functional change, end to end.</div>
      </div>
      <div class="fw-step reveal">
        <div class="fw-node">03</div>
        <div class="fw-verb">Measure</div>
        <div class="fw-phrase">what matters through governance, KPIs and data-led performance.</div>
      </div>
      <div class="fw-step reveal">
        <div class="fw-node">04</div>
        <div class="fw-verb">Align</div>
        <div class="fw-phrase">the stakeholders so the change is embedded and sustained.</div>
      </div>
    </div>
  </div>
</section>

<!-- AT A GLANCE -->
<section class="impact" id="impact">
  <div class="wrap">
    <div class="ihead reveal-l">At a glance</div>
    <div class="impact-grid">
      {% for s in atglance.stats %}
      <div class="istat reveal"><div class="num">{% if s.animate %}{% if s.prefix %}<span class="pre">{{ s.prefix }}</span>{% endif %}<span data-count="{{ s.value }}">0</span>{% if s.suffix %}<span class="suf">{{ s.suffix }}</span>{% endif %}{% else %}{{ s.prefix }}{{ s.value }}{{ s.suffix }}{% endif %}</div><div class="label">{{ s.label }}</div></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- SECTORS -->
<section class="clients">
  <div class="wrap reveal">
    <div class="lbl">{{ sectors.heading }}</div>
    <div class="client-row">
      {% for i in sectors.items %}<span>{{ i }}</span>{% endfor %}
    </div>
  </div>
</section>

<!-- PHILOSOPHY -->
<section class="philosophy">
  <canvas id="node-canvas" aria-hidden="true"></canvas>
  <div class="wrap reveal">
    <div class="kicker">How I work</div>
    <blockquote>Strategy is easy to write and hard to land. The real work is in what gets <em>built, adopted, and sustained</em>, long after the plan is filed.</blockquote>
  </div>
</section>

<!-- ABOUT / TIMELINE -->
<section class="block" id="about">
  <div class="wrap">
    <div class="kicker reveal-l">My story</div>
    <h2 class="big reveal">From engineer to <span class="serif">transformation leader.</span></h2>
    <p class="lead-p reveal">A career that began at the engineering coalface and grew into leading complex, cross-functional change across engineering, quality and operations. The through-line: a structured, analytical approach to making complex things work, and embedding change that lasts, without disrupting the operations it depends on.</p>
    <div class="timeline">
      {% for c in timeline.chapters %}
      <div class="tl-row reveal">
        <div class="tn">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</div>
        <div><div class="yrs">{{ c.period }}</div><h3>{{ c.title }}</h3></div>
        <p>{{ c.body | safe }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- EXPERTISE -->
<section class="block work" id="expertise">
  <div class="wrap">
    <div class="kicker reveal-l">What I do</div>
    <h2 class="big reveal">Where I create <span class="serif">value.</span></h2>
    <p class="lead-p reveal">I bring a structured, analytical approach to complex problems, particularly where delivery reliability, quality and operational performance are critical, and change must land without disrupting core operations. Four capabilities sit at the centre of my work.</p>
    <div class="work-grid">
      {% for p in expertise.pillars %}
      <div class="wc reveal"><span class="tag">{{ p.tag }}</span><h3>{{ p.title }}</h3><p>{{ p.body }}</p></div>
      {% endfor %}
      <div class="wc wide reveal">
        <div class="wide-inner">
          <div><span class="tag">Underpinning it all</span><h3>Capability Building</h3></div>
          <p>Developing high-performing teams through recruitment, training and coaching, and building the internal capability for change to outlast any single programme. The people are what make transformation stick.</p>
        </div>
      </div>
    </div>
    <p class="work-note">Experience rooted in aerospace and advanced manufacturing, with principles that travel to any regulated, complex sector.</p>
  </div>
</section>

<!-- FELLOWSHIP -->
<section class="block ff" id="fellowship">
  <div class="wrap ff-grid">
    <div class="reveal">
      <div class="kicker">A cause close to me</div>
      <h2>The Tayorski <span class="serif">Fellowship.</span></h2>
      <p>In 2026 I founded a fellowship to celebrate Nigerian students who embody curiosity, excellence, and the drive to apply their learning to real problems. It begins as a single annual prize, built to grow into a scholarship, and one day, a living community of Fellows.</p>
      <a href="https://tayorskifellowship.org" class="btn-terra">Visit the Fellowship →</a>
    </div>
    <div class="ff-visual reveal">
      <div class="ring"></div>
      <div class="big-t">T</div>
    </div>
  </div>
</section>

<!-- WRITING -->
<section class="block" id="writing">
  <div class="wrap">
    <div class="kicker reveal-l">Writing &amp; thinking</div>
    <h2 class="big reveal">Ideas worth <span class="serif">sharing.</span></h2>
    <p class="lead-p reveal">Occasional essays on transformation, leadership, engineering, and giving back. <span style="font-style:italic">(Even one a quarter builds real authority.)</span></p>
    <div class="writing-grid">
      {% set recent = collections.posts | limit(3) %}
      {% for post in recent %}
      <a class="post reveal" href="{{ post.url }}" style="text-decoration:none;color:inherit;">
        <div class="post-top"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg></div>
        <div class="post-body">{% if post.data.category %}<span class="cat">{{ post.data.category }}</span>{% endif %}<h3>{{ post.data.title }}</h3><p>{{ post.data.excerpt }}</p></div>
      </a>
      {% endfor %}
      {% if medium %}{% set mediumPosts = medium | limit(3) %}{% for m in mediumPosts %}
      <a class="post reveal" href="{{ m.link }}" style="text-decoration:none;color:inherit;">
        <div class="post-top"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <div class="post-body"><span class="cat">Medium</span><h3>{{ m.title }}</h3><p>{{ m.excerpt }}…</p></div>
      </a>
      {% endfor %}{% endif %}
    </div>
    <p style="margin-top:32px"><a href="/blog/" class="btn-line">All writing</a></p>
  </div>
</section>

<!-- BEYOND WORK -->
<section class="block beyond" id="beyond">
  <div class="wrap">
    <div class="kicker reveal-l">Beyond work</div>
    <h2 class="big reveal">Away from the <span class="serif">day job.</span></h2>
    <p class="lead-p reveal">The same curiosity that drives my work tends to show up everywhere else too. When I am not leading change programmes, you will usually find me behind a camera or supporting young people closer to home.</p>
    <div class="beyond-grid">
      <div class="by-item reveal">
        <h3>Photography</h3>
        <p>A long-standing creative pursuit, and a separate venture of its own. A different way of paying attention to the world, and of seeing what others walk past.</p>
        <a href="https://tayorskiphotography.com" class="by-link">View my photography <span>&rarr;</span></a>
      </div>
      <div class="by-item reveal">
        <h3>Community &amp; governance</h3>
        <p>Serving as a school governor in Derby, helping shape the education and opportunities of the next generation of young people in my own community.</p>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="block contact" id="contact">
  <div class="wrap reveal">
    <h2>Let's build <span class="serif">something.</span></h2>
    <p>Whether it is a transformation programme, a board or governance role, a speaking invitation, or a Fellowship partnership, I would welcome the conversation.</p>
    <div class="contact-cta">
      <a href="mailto:{{ profile.email }}" class="btn-solid">Email me</a>
      <a href="{{ profile.linkedin }}" class="btn-line">Connect on LinkedIn</a>
    </div>
  </div>
</section>


<script>
  function tick() {
    const now = new Date();
    const uk = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/London' }));
    const h = String(uk.getHours()).padStart(2,'0');
    const m = String(uk.getMinutes()).padStart(2,'0');
    const s = String(uk.getSeconds()).padStart(2,'0');
    const el = document.getElementById('clock');
    if (el) el.textContent = `${h}:${m}:${s}`;
  }
  setInterval(tick, 1000); tick();

  // Connected-nodes background (philosophy section)
  (function () {
    const canvas = document.getElementById('node-canvas');
    if (!canvas) return;
    const section = canvas.closest('section');
    const ctx = canvas.getContext('2d');
    const COLOR = '70, 170, 164';      // teal-light
    const MAXDIST = 132;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let w = 0, h = 0, dpr = 1, particles = [], raf = null;
    const mouse = { x: null, y: null };

    function size() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      const r = section.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function init() {
      const n = Math.max(22, Math.min(56, Math.floor(w / 24)));
      particles = [];
      for (let i = 0; i < n; i++) {
        particles.push({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.32, vy: (Math.random() - 0.5) * 0.32,
          r: Math.random() * 1.6 + 1.1
        });
      }
    }
    function frame(loop) {
      ctx.clearRect(0, 0, w, h);
      for (const p of particles) {
        if (!reduce) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > w) p.vx *= -1;
          if (p.y < 0 || p.y > h) p.vy *= -1;
        }
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + COLOR + ', 0.6)';
        ctx.fill();
      }
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x, dy = a.y - b.y, d = Math.hypot(dx, dy);
          if (d < MAXDIST) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = 'rgba(' + COLOR + ',' + (0.16 * (1 - d / MAXDIST)) + ')';
            ctx.lineWidth = 1; ctx.stroke();
          }
        }
        if (mouse.x != null) {
          const dx = a.x - mouse.x, dy = a.y - mouse.y, d = Math.hypot(dx, dy);
          if (d < MAXDIST * 1.5) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y); ctx.lineTo(mouse.x, mouse.y);
            ctx.strokeStyle = 'rgba(' + COLOR + ',' + (0.3 * (1 - d / (MAXDIST * 1.5))) + ')';
            ctx.lineWidth = 1; ctx.stroke();
          }
        }
      }
      if (loop && !reduce) raf = requestAnimationFrame(() => frame(true));
    }
    function start() { size(); init(); cancelAnimationFrame(raf); frame(!reduce); }
    window.addEventListener('resize', () => { size(); init(); if (reduce) frame(false); });
    section.addEventListener('mousemove', (e) => {
      const r = section.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
    });
    section.addEventListener('mouseleave', () => { mouse.x = null; mouse.y = null; });
    // Start once the section is near view to avoid measuring 0-height
    const io = new IntersectionObserver((ents) => {
      ents.forEach(en => { if (en.isIntersecting) { start(); io.disconnect(); } });
    }, { threshold: 0.05 });
    io.observe(section);
  })();

  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => { if (e.isIntersecting) { setTimeout(() => e.target.classList.add('in'), (i % 4) * 110); obs.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal, .reveal-l, .reveal-r').forEach(el => obs.observe(el));

  const counted = new Set();
  const cObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting && !counted.has(e.target)) {
        counted.add(e.target);
        const target = parseInt(e.target.dataset.count, 10);
        let cur = 0; const step = Math.max(1, Math.ceil(target / 24));
        const t = setInterval(() => { cur += step; if (cur >= target) { cur = target; clearInterval(t); } e.target.textContent = cur; }, 40);
      }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => cObs.observe(el));

  document.getElementById('menuBtn').addEventListener('click', () => {
    const links = document.querySelector('nav.links');
    if (links.style.display === 'flex') { links.style.display = 'none'; }
    else {
      links.style.display = 'flex'; links.style.position = 'absolute'; links.style.top = '114px';
      links.style.right = '22px'; links.style.flexDirection = 'column'; links.style.background = 'var(--paper)';
      links.style.padding = '22px 28px'; links.style.gap = '16px'; links.style.border = '1px solid var(--line)';
      links.style.boxShadow = '0 12px 30px rgba(0,0,0,0.1)'; links.style.zIndex = '200';
    }
  });
</script>
